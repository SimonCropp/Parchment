<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="local" value="../nugets" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <!-- Pin Parchment to the local feed. Without this, NuGet sees Parchment 0.4.5 in BOTH
       feeds (locally-built nupkg in ../nugets AND the published one on nuget.org) and
       picks nondeterministically — on CI it consistently picks nuget.org and we get the
       published bits, missing any in-progress source-generator changes. PackageSourceMapping
       forces Parchment.* to come from `local` regardless of what nuget.org has. -->
  <packageSourceMapping>
    <packageSource key="local">
      <package pattern="Parchment" />
      <package pattern="Parchment.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
